{
  "name": "teammind",
  "version": "0.1.0",
  "private": true,
  "description": "TeamMindAI · AI 企业大脑平台 — 多 Agent 智能协作中台",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:indexes": "prisma db execute --file prisma/indexes.sql --schema prisma/schema.prisma",
    "worker": "tsx --env-file=.env src/worker/index.ts",
    "worker:dev": "tsx watch --env-file=.env src/worker/index.ts",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.50",
    "@ai-sdk/react": "^3.0.208",
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.1071.0",
    "@prisma/client": "^6.1.0",
    "@radix-ui/react-slot": "^1.3.0",
    "ai": "^6.0.206",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "date-fns": "^4.4.0",
    "ffmpeg-static": "^5.3.0",
    "ioredis": "^5.4.2",
    "lucide-react": "^1.18.0",
    "mammoth": "^1.12.0",
    "nanoid": "^5.1.11",
    "next": "^15.1.0",
    "next-auth": "^5.0.0-beta.31",
    "pdf-parse": "1.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^20.17.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "prisma": "^6.1.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
