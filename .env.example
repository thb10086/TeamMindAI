# =========================================================
# TeamMindAI · 环境变量示例（复制为 .env 并填入真实值）
# cp .env.example .env
# =========================================================

# ---------- App ----------
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=TeamMindAI
APP_URL=http://localhost:3000

# ---------- Auth.js (next-auth v5) ----------
# 生成: openssl rand -base64 33
AUTH_SECRET=replace-me-with-a-random-secret
AUTH_TRUST_HOST=true

# ---------- Database: PostgreSQL + pgvector ----------
# 宿主机端口映射为 5434，避免与本机其它项目占用的 5432/5433 冲突
DATABASE_URL=postgresql://teammind:teammind@localhost:5434/teammind?schema=public

# ---------- Redis (BullMQ 异步任务/通知/定时报告) ----------
# 宿主机端口映射为 6381，避免与本机其它项目占用的 6379/6380 冲突
REDIS_URL=redis://localhost:6381

# ---------- AgentLLM Gateway (OpenAI 兼容) ----------
AGENTLLM_BASE_URL=https://agentllm.linkyun.co/v1
AGENTLLM_API_KEY=sk-your-key-here
# 默认模型（完整列表: GET /v1/models）
AGENTLLM_CHAT_MODEL=claude-sonnet
AGENTLLM_FAST_MODEL=gemini-3.5-flash
AGENTLLM_EMBEDDING_MODEL=text-embedding-3-large
# text-embedding-3-large 原生 3072 维，降到 1536 以兼容 pgvector 索引(<=2000)
AGENTLLM_EMBEDDING_DIM=1536
# 文生图模型（会议封面图等）。注意：网关暂无 ASR 转写端点，音频转写改走 yunwu.ai
AGENTLLM_IMAGE_MODEL=gpt-image-2
# 图片/截图内容识别（Vision），需模型支持多模态。gpt-4o-mini 在大多数网关可用
AGENTLLM_VISION_MODEL=gpt-4o-mini

# ---------- 语音转写 ASR (yunwu.ai，OpenAI 兼容) ----------
# AgentLLM 网关暂无 transcriptions 端点，故音频转写走 yunwu.ai。
# whisper-1 返回 verbose_json（含分段时间戳），配合 LLM 做说话人识别。
ASR_BASE_URL=https://yunwu.ai/v1
ASR_API_KEY=sk-your-yunwu-key-here
# 可选 whisper-1 / gpt-4o-transcribe（后者无时间戳，说话人识别效果略弱）
ASR_MODEL=whisper-1

# ---------- 对象存储 (MinIO / S3) ----------
# 注意：宿主机端口映射为 9002(API)/9003(控制台)，避免与本机已占用的 9000 冲突
S3_ENDPOINT=http://localhost:9002
S3_REGION=us-east-1
S3_ACCESS_KEY=teammind
S3_SECRET_KEY=teammind123
S3_BUCKET=teammind

# ---------- SMTP 邮件通知 ----------
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="TeamMindAI <noreply@example.com>"

# ---------- 联网搜索 (Tavily) ----------
# 用于 AI 对齐室「近 30 天竞品/同行分析」，辅助决策。
# 申请: https://app.tavily.com  。留空则该功能在前端整体隐藏。
TAVILY_API_KEY=
